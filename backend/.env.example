APP_NAME=Enterprise Agentic RAG Knowledge Assistant
APP_VERSION=1.0.0
APP_ENV=development

# LLM provider: "ollama" or "openai"
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (uncomment to use)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Embeddings: "local" (HuggingFace) or "openai"
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Storage paths
CHROMA_DB_PATH=app/storage/chroma_db
UPLOAD_DIR=app/storage/uploaded_docs
DATABASE_URL=sqlite:///./app/storage/app.db

# API authentication key — change this in production
API_KEY=dev-secret-key-change-this
